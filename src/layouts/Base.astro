---
import { SITE, buildWebAppSchema } from "../lib/seo";
import "../styles/global.css";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  schema?: string;
}
const { title, description = SITE.desc, canonical, schema } = Astro.props;
const url = canonical ? `${SITE.url}${canonical}` : SITE.url;
const ogimage = "/og-image-lp.webp";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <title>{title} | {SITE.name}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={`${title} | ${SITE.name}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={ogimage} />
    <meta name="robots" content="index,follow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script type="application/ld+json" set:html={buildWebAppSchema()} />
    <!-- {schema && <script type="application/ld+json" set:html={schema} />} -->

    <!-- Google Analytics -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-G5Z9DGM1SH"
    ></script>
    <script is:inline>
      if (window.location.hostname !== "localhost") {
        window.dataLayer = window.dataLayer || [];
        function gtag() {
          dataLayer.push(arguments);
        }
        gtag("js", new Date());
        gtag("config", "G-G5Z9DGM1SH");
      }
    </script>
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
