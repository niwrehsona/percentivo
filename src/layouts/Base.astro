---
import { SITE, buildWebAppSchema } from "../lib/seo";
import "../styles/global.css";
interface Props {
  title: string;
  description?: string;
  canonical?: string;
  schema?: string;
}
const { title, description = SITE.desc, canonical, schema } = Astro.props;
const url = canonical ? `${SITE.url}${canonical}` : SITE.url;

const gaId = import.meta.env.PUBLIC_GA_ID as string | undefined;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="theme-color" content="#2563eb" />
    <title>{title} | {SITE.name}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <meta property="og:title" content={`${title} | ${SITE.name}`} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={url} />
    <meta property="og:type" content="website" />
    <meta name="robots" content="index,follow" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <script type="application/ld+json" set:html={buildWebAppSchema()} />
    {schema && <script type="application/ld+json" set:html={schema} />}
    {gaId && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${gaId}`}></script>
        <script define:vars={{ gaId }}>
          window.dataLayer = window.dataLayer || [];
          function gtag(){dataLayer.push(arguments);}
          gtag('js', new Date());
          gtag('config', gaId);
        </script>
      </>
    )}
  </head>
  <body class="bg-gray-50 text-gray-900 antialiased">
    <header
      class="sticky top-0 z-50 bg-white border-b border-gray-200 shadow-sm"
    >
      <div
        class="max-w-6xl mx-auto px-4 h-14 flex items-center justify-between"
      >
        <a
          href="/"
          class="flex items-center gap-2 font-bold text-lg text-blue-600"
        >
          <span class="text-2xl" aria-hidden="true">
            <img src="/logo-percentivo.svg" alt="Percentivo logo" width="24" />
          </span>
          <span class="hidden sm:inline font-bold">PERCENTIVO</span>
        </a>
        <nav
          class="hidden md:flex items-center gap-6"
          aria-label="Main navigation"
        >
          <div class="relative group">
            <button
              class="flex items-center gap-1 text-sm text-gray-700 hover:text-blue-600 font-medium py-4"
              aria-haspopup="true"
            >
              Calculators
              <svg
                class="w-3.5 h-3.5 transition-transform group-hover:rotate-180"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
                aria-hidden="true"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M19 9l-7 7-7-7"></path>
              </svg>
            </button>
            <div
              class="absolute top-full left-0 w-56 bg-white border border-gray-200 rounded-xl shadow-lg z-50 opacity-0 invisible pointer-events-none group-hover:opacity-100 group-hover:visible group-hover:pointer-events-auto transition-all duration-150"
              role="menu"
            >
              <a
                href="/percentage-of-number"
                role="menuitem"
                class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700 rounded-t-xl"
                >Percentage of Number</a
              >
              <a
                href="/percentage-increase"
                role="menuitem"
                class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700"
                >Percentage Increase</a
              >
              <a
                href="/percentage-decrease"
                role="menuitem"
                class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700"
                >Percentage Decrease</a
              >
              <a
                href="/discount-calculator"
                role="menuitem"
                class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700"
                >Discount Calculator</a
              >
              <a
                href="/markup-calculator"
                role="menuitem"
                class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700"
                >Markup Calculator</a
              >
              <a
                href="/tax-calculator"
                role="menuitem"
                class="block px-4 py-2.5 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-700 rounded-b-xl"
                >Tax Calculator</a
              >
            </div>
          </div>
          <a
            href="/blog"
            class="text-sm text-gray-700 hover:text-blue-600 font-medium"
            >Blog</a
          >
        </nav>
        <mobile-menu class="md:hidden">
          <button
            id="menu-btn"
            class="p-2 text-gray-700"
            aria-label="Open menu"
            aria-expanded="false"
            aria-controls="mobile-nav"
          >
            <svg
              class="w-5 h-5"
              id="icon-open"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M4 6h16M4 12h16M4 18h16"></path>
            </svg>
            <svg
              class="w-5 h-5 hidden"
              id="icon-close"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
          <div
            id="mobile-nav"
            aria-hidden="true"
            class="absolute top-14 left-0 right-0 bg-white border-t border-gray-200 shadow-md z-50 px-4 py-3 space-y-1
                 transition-all duration-200 origin-top opacity-0 scale-y-0 pointer-events-none"
          >
            <div>
              <button
                id="calc-btn"
                class="w-full flex items-center justify-between py-2 text-sm font-medium text-gray-700"
                aria-expanded="false"
              >
                Calculators
                <svg
                  id="calc-icon"
                  class="w-3.5 h-3.5 transition-transform"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke="currentColor"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M19 9l-7 7-7-7"></path>
                </svg>
              </button>
              <div
                id="calc-nav"
                class="pl-4 space-y-1 overflow-hidden max-h-0 transition-all duration-200"
              >
                <a
                  href="/percentage-of-number"
                  class="block py-1.5 text-sm text-gray-600 hover:text-blue-600"
                  >Percentage of Number</a
                >
                <a
                  href="/percentage-increase"
                  class="block py-1.5 text-sm text-gray-600 hover:text-blue-600"
                  >Percentage Increase</a
                >
                <a
                  href="/percentage-decrease"
                  class="block py-1.5 text-sm text-gray-600 hover:text-blue-600"
                  >Percentage Decrease</a
                >
                <a
                  href="/discount-calculator"
                  class="block py-1.5 text-sm text-gray-600 hover:text-blue-600"
                  >Discount Calculator</a
                >
                <a
                  href="/markup-calculator"
                  class="block py-1.5 text-sm text-gray-600 hover:text-blue-600"
                  >Markup Calculator</a
                >
                <a
                  href="/tax-calculator"
                  class="block py-1.5 text-sm text-gray-600 hover:text-blue-600"
                  >Tax Calculator</a
                >
              </div>
            </div>
            <a
              href="/blog"
              class="block py-2 text-sm font-medium text-gray-700 hover:text-blue-600"
              >Blog</a
            >
          </div>
        </mobile-menu>
      </div>
    </header>

    <main><slot /></main>

    <footer class="bg-gray-900 text-gray-400 mt-16">
      <div
        class="max-w-6xl mx-auto px-4 py-12 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8"
      >
        <div>
          <div
            class="text-white font-bold text-lg mb-3 flex items-center gap-2"
          >
            <span class="text-2xl text-blue-400">
              <img
                src="/logo-percentivo.svg"
                alt="Percentivo logo"
                width="24"
              />
            </span> PERCENTIVO
          </div>
          <p class="text-sm leading-relaxed">
            Free online percentage calculators. Fast, accurate, no signup
            required.
          </p>
        </div>
        <div>
          <h3
            class="text-white font-semibold text-sm mb-3 uppercase tracking-wide"
          >
            Calculators
          </h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a
                href="/percentage-of-number"
                class="hover:text-white transition-colors"
                >Percentage of Number</a
              >
            </li>
            <li>
              <a
                href="/percentage-increase"
                class="hover:text-white transition-colors"
                >Percentage Increase</a
              >
            </li>
            <li>
              <a
                href="/percentage-decrease"
                class="hover:text-white transition-colors"
                >Percentage Decrease</a
              >
            </li>
            <li>
              <a
                href="/discount-calculator"
                class="hover:text-white transition-colors"
                >Discount Calculator</a
              >
            </li>
            <li>
              <a
                href="/markup-calculator"
                class="hover:text-white transition-colors">Markup Calculator</a
              >
            </li>
            <li>
              <a
                href="/tax-calculator"
                class="hover:text-white transition-colors">Tax Calculator</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h3
            class="text-white font-semibold text-sm mb-3 uppercase tracking-wide"
          >
            Resources
          </h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a href="/blog" class="hover:text-white transition-colors">Blog</a
              >
            </li>
            <li>
              <a
                href="/blog/how-to-calculate-percentage"
                class="hover:text-white transition-colors">How to Calculate %</a
              >
            </li>
            <li>
              <a
                href="/blog/percentage-formulas"
                class="hover:text-white transition-colors"
                >Percentage Formulas</a
              >
            </li>
            <li>
              <a
                href="/blog/discount-vs-markup"
                class="hover:text-white transition-colors">Discount vs Markup</a
              >
            </li>
          </ul>
        </div>
        <div>
          <h3
            class="text-white font-semibold text-sm mb-3 uppercase tracking-wide"
          >
            Popular Calculations
          </h3>
          <ul class="space-y-2 text-sm">
            <li>
              <a
                href="/what-is/15-percent-of-200"
                class="hover:text-white transition-colors"
                >What is 15% of 200?</a
              >
            </li>
            <li>
              <a
                href="/what-is/20-percent-of-50"
                class="hover:text-white transition-colors">What is 20% of 50?</a
              >
            </li>
            <li>
              <a
                href="/what-is/10-percent-of-1000"
                class="hover:text-white transition-colors"
                >What is 10% of 1000?</a
              >
            </li>
            <li>
              <a
                href="/what-is/25-percent-of-80"
                class="hover:text-white transition-colors">What is 25% of 80?</a
              >
            </li>
          </ul>
        </div>
      </div>
      <div class="border-t border-gray-800">
        <div
          class="max-w-6xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-2 text-xs text-gray-500"
        >
          <span
            >© {new Date().getFullYear()} Percentivo. All rights reserved.</span
          >
          <span>Free online calculator tools</span>
        </div>
      </div>
    </footer>

    <script>
      class MobileMenuEl extends HTMLElement {
        connectedCallback() {
          const btn = this.querySelector("#menu-btn")!;
          const nav = this.querySelector("#mobile-nav")!;
          const iconO = this.querySelector("#icon-open")!;
          const iconC = this.querySelector("#icon-close")!;
          const calcBtn = this.querySelector("#calc-btn")!;
          const calcNav = this.querySelector("#calc-nav")!;
          const calcIcon = this.querySelector("#calc-icon")!;
          let open = false,
            calcOpen = false;

          btn.addEventListener("click", () => {
            open = !open;
            nav.classList.toggle("opacity-100", open);
            nav.classList.toggle("scale-y-100", open);
            nav.classList.toggle("pointer-events-auto", open);
            nav.classList.toggle("opacity-0", !open);
            nav.classList.toggle("scale-y-0", !open);
            nav.classList.toggle("pointer-events-none", !open);
            nav.setAttribute("aria-hidden", String(!open));
            btn.setAttribute("aria-expanded", String(open));
            iconO.classList.toggle("hidden", open);
            iconC.classList.toggle("hidden", !open);
          });

          calcBtn.addEventListener("click", () => {
            calcOpen = !calcOpen;
            calcNav.classList.toggle("max-h-96", calcOpen);
            calcNav.classList.toggle("max-h-0", !calcOpen);
            (calcIcon as HTMLElement).style.transform = calcOpen
              ? "rotate(180deg)"
              : "";
            calcBtn.setAttribute("aria-expanded", String(calcOpen));
          });
        }
      }
      customElements.define("mobile-menu", MobileMenuEl);
    </script>
  </body>
</html>
