---
import Base from "../layouts/Base.astro";
import FAQSection from "../components/FAQSection.astro";
import RelatedCalculators from "../components/RelatedCalculators.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
import DiscountCalculator from "../components/DiscountCalculator.astro";
const faqs = [
  { question:"How do I calculate 20% off a price?", answer:"Multiply the price by 0.80 (which is 1 − 0.20). For example, 20% off $50 = $50 × 0.80 = $40." },
  { question:"What is the difference between discount and markdown?", answer:"A discount is a reduction given to the buyer. A markdown is a permanent price reduction by the retailer." },
  { question:"How do I find the original price if I only know the sale price?", answer:"Divide the sale price by (1 − discount/100). If you paid $68 after 15% off: $68 ÷ 0.85 = $80." },
  { question:"Can you apply two discounts together?", answer:"Yes, but they compound — they do not add. 20% then 10% off is not 30% off. On $100: after 20% = $80, then 10% = $72. Combined saving is 28%, not 30%." },
];
const refPrices = [20,50,100,200,500,1000];
const refDiscs  = [10,15,20,25,50];
---
<Base title="Discount Calculator – Calculate % Off Any Price"
  description="Calculate sale price, discount amount, or original price. Three modes in one free online discount calculator."
  canonical="/discount-calculator">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={[{label:"Home",href:"/"},{label:"Discount Calculator"}]}/>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Discount Calculator</h1>
    <p class="text-gray-600 mb-8">Calculate sale price, discount amount, or original price — three modes in one tool.</p>
    <div class="mb-8"><DiscountCalculator/></div>

    <div class="grid sm:grid-cols-2 gap-6 mb-8">
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <h2 class="font-bold text-gray-900 mb-3">Three Discount Formulas</h2>
        {[
          ["Sale price:","Price = Original × (1 − Discount/100)"],
          ["Discount %:", "% = ((Original − Sale) ÷ Original) × 100"],
          ["Original price:","Original = Sale ÷ (1 − Discount/100)"],
        ].map(([l,f])=>(
          <div class="mb-3 last:mb-0">
            <div class="text-xs text-gray-500 mb-1">{l}</div>
            <div class="bg-blue-50 border border-blue-100 rounded-lg px-3 py-2 font-mono text-blue-800 text-xs">{f}</div>
          </div>
        ))}
        <div class="mt-3 bg-green-50 border border-green-200 rounded-lg p-3 text-xs text-green-800">
          💡 Mental math: find 10% (move decimal left), then multiply. 25% off $80 = 10% ($8) × 2.5 = $20 off.
        </div>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <h2 class="font-bold text-gray-900 mb-3">Step-by-Step: 25% off $80</h2>
        {[["1","Convert: 25 ÷ 100 = 0.25"],["2","Subtract from 1: 1 − 0.25 = 0.75"],["3","Multiply: $80 × 0.75 = $60"],["4","Saving: $80 − $60 = $20"]].map(([n,t])=>(
          <div class="flex gap-3 items-start mb-2.5 last:mb-0">
            <span class="w-6 h-6 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">{n}</span>
            <span class="text-sm text-gray-700">{t}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl p-5 mb-8 overflow-x-auto">
      <h2 class="font-bold text-gray-900 mb-4">Quick Reference — Common Discounts</h2>
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-gray-200">
            <th class="text-left px-3 py-2 font-medium text-gray-500">Original</th>
            {refDiscs.map(d=><th class="text-right px-3 py-2 font-medium text-gray-500">{d}% off</th>)}
          </tr>
        </thead>
        <tbody>
          {refPrices.map(p=>(
            <tr class="border-b border-gray-100 last:border-0">
              <td class="px-3 py-2 font-medium text-gray-900">${p}</td>
              {refDiscs.map(d=><td class="px-3 py-2 text-right text-green-700 font-medium">${(p*(1-d/100)).toFixed(2)}</td>)}
            </tr>
          ))}
        </tbody>
      </table>
    </div>

    <FAQSection faqs={faqs}/>
    <RelatedCalculators items={[
      {label:"Markup Calculator",   href:"/markup-calculator",   desc:"Selling price from cost"},
      {label:"Tax Calculator",      href:"/tax-calculator",      desc:"Sales tax and VAT"},
      {label:"% Increase",          href:"/percentage-increase", desc:"Growth between two values"},
      {label:"% of Number",         href:"/percentage-of-number",desc:"What is X% of Y?"},
    ]}/>
  </div>
</Base>
