---
import Base from "../layouts/Base.astro";
import MainCalculator from "../components/MainCalculator.astro";
import FAQSection from "../components/FAQSection.astro";
import { buildFAQSchema } from "../lib/seo";

const faqs = [
  {
    question: "How do I calculate a percentage of a number?",
    answer:
      "Multiply the number by the percentage divided by 100. For example, 15% of 200 = 200 × 0.15 = 30.",
  },
  {
    question: "How do I calculate percentage increase?",
    answer:
      "Use the formula: ((New − Old) ÷ Old) × 100. From 80 to 100: ((100 − 80) ÷ 80) × 100 = 25% increase.",
  },
  {
    question: "What is the percentage formula?",
    answer: "The core formula is: Percentage = (Part ÷ Whole) × 100.",
  },
  {
    question: "How do I find what percentage one number is of another?",
    answer:
      "Divide the first by the second, then multiply by 100. 30 is what % of 200? (30 ÷ 200) × 100 = 15%.",
  },
  {
    question: "How do I calculate a discount percentage?",
    answer: "Formula: ((Original − Sale) ÷ Original) × 100.",
  },
  {
    question:
      "What is the difference between percentage and percentage points?",
    answer:
      "A percentage is a relative measure. Percentage points describe absolute arithmetic difference. If a rate rises from 2% to 3%, that is 1 percentage point but a 50% relative increase.",
  },
];
const calculators = [
  {
    label: "% of Number",
    href: "/percentage-of-number",
    icon: "÷",
    desc: "What is X% of Y?",
  },
  {
    label: "% Increase",
    href: "/percentage-increase",
    icon: "↑",
    desc: "Growth rate between values",
  },
  {
    label: "% Decrease",
    href: "/percentage-decrease",
    icon: "↓",
    desc: "Reduction between values",
  },
  {
    label: "Discount",
    href: "/discount-calculator",
    icon: "🏷",
    desc: "Sale price & savings",
  },
  {
    label: "Markup",
    href: "/markup-calculator",
    icon: "$",
    desc: "Selling price from cost",
  },
  {
    label: "Tax",
    href: "/tax-calculator",
    icon: "🧾",
    desc: "Sales tax & VAT",
  },
];
const popular = [
  { pct: 15, of: 200 },
  { pct: 20, of: 50 },
  { pct: 10, of: 1000 },
  { pct: 25, of: 80 },
  { pct: 5, of: 500 },
  { pct: 30, of: 150 },
  { pct: 50, of: 200 },
  { pct: 8.5, of: 100 },
];
---

<Base
  title="Percentage Calculator – Free Online Tool"
  description="Calculate any percentage instantly. Percentage of a number, increase, decrease, discount, markup, tax and more. Free, fast, no signup."
  canonical="/"
  schema={buildFAQSchema(faqs)}
>
  <section
    class="bg-gradient-to-b from-blue-600 to-blue-700 text-white py-14 px-4"
  >
    <div class="max-w-3xl mx-auto text-center">
      <h1 class="text-4xl sm:text-5xl font-bold mb-3 tracking-tight">
        Percentage Calculator
      </h1>
      <p class="text-blue-100 text-lg mb-10">
        Calculate any percentage instantly — free, fast, no signup needed.
      </p>
      <MainCalculator />
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-12 below-fold">
    <h2 class="text-2xl font-bold text-gray-900 mb-2 text-center">
      All Calculators
    </h2>
    <p class="text-gray-500 text-center mb-8 text-sm">
      Specialised tools for every percentage calculation need
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
      {
        calculators.map((c) => (
          <a
            href={c.href}
            class="group bg-white border border-gray-200 rounded-2xl p-5 hover:border-blue-300 hover:shadow-md transition-all"
          >
            <div class="text-3xl mb-3">{c.icon}</div>
            <div class="font-semibold text-gray-900 group-hover:text-blue-700 mb-1">
              {c.label}
            </div>
            <div class="text-xs text-gray-500">{c.desc}</div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="bg-white border-y border-gray-200 py-12 px-4 below-fold">
    <div class="max-w-3xl mx-auto">
      <h2 class="text-2xl font-bold text-gray-900 mb-4">
        What is a Percentage?
      </h2>
      <p class="text-gray-700 leading-relaxed mb-4">
        A <strong>percentage</strong> is a way of expressing a number as a fraction
        of 100. The word comes from the Latin <em>per centum</em>, meaning "by
        the hundred." Percentages appear everywhere — shopping discounts, tax
        rates, exam scores, investment returns.
      </p>
      <div
        class="bg-blue-50 border border-blue-200 rounded-xl px-6 py-4 text-center font-mono text-blue-800 text-lg mb-8"
      >
        Percentage = (Part ÷ Whole) × 100
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {
          [
            { pct: 20, of: 85, label: "20% off $85", ctx: "Shopping discount" },
            { pct: 8.5, of: 120, label: "8.5% tax on $120", ctx: "Sales tax" },
            {
              pct: 15,
              of: 65,
              label: "15% tip on $65 bill",
              ctx: "Restaurant tip",
            },
            {
              pct: 50,
              of: 40,
              label: "50% markup on $40",
              ctx: "Business pricing",
            },
          ].map((ex) => (
            <div class="bg-gray-50 border border-gray-200 rounded-xl p-4">
              <div class="text-xs text-gray-500 mb-1">{ex.ctx}</div>
              <div class="font-semibold text-gray-900">{ex.label}</div>
              <div class="text-blue-700 font-mono text-sm mt-1">
                = {parseFloat(((ex.pct / 100) * ex.of).toFixed(2))}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="max-w-5xl mx-auto px-4 py-12 below-fold">
    <h2 class="text-2xl font-bold text-gray-900 mb-2">Popular Calculations</h2>
    <p class="text-gray-500 text-sm mb-6">
      Quick answers to the most-searched percentage questions
    </p>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {
        popular.map(({ pct, of }) => (
          <a
            href={`/what-is/${pct}-percent-of-${of}`}
            class="bg-white border border-gray-200 rounded-xl p-3 text-sm hover:border-blue-300 hover:bg-blue-50 transition-all text-center"
          >
            <div class="font-medium text-gray-800">
              What is {pct}% of {of}?
            </div>
            <div class="text-blue-600 font-semibold mt-1">
              = {parseFloat(((pct / 100) * of).toFixed(4))}
            </div>
          </a>
        ))
      }
    </div>
  </section>

  <section class="max-w-3xl mx-auto px-4 pb-12 below-fold">
    <FAQSection faqs={faqs} />
  </section>
</Base>
