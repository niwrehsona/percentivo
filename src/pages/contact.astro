---
import Base from "../layouts/Base.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
---

<Base
  title="Contact | Percentivo"
  description="Description"
  canonical="/contact"
>
  <div class="max-w-3xl mx-auto px-4 py-8">
    <Breadcrumb items={[{ label: "Home", href: "/" }, { label: "Contact" }]} />

    <header class="mb-8">
      <h1
        class="text-3xl sm:text-4xl font-bold text-gray-900 mb-4 leading-tight"
      >
        Contact Us
      </h1>
      <p class="mb-4">Percentivo.com — Get in Touch</p>

      <h2 class="text-2xl font-bold mb-3">We'd Love to Hear from You.</h2>
      <p>
        Have a question about one of our calculators? Found an error you'd like
        to report? Want to suggest a new tool, explore a partnership, or just
        say hello? We read every message and do our best to respond promptly.
      </p>
    </header>

    <article class="prose max-w-none">
      <h2 class="text-2xl font-bold mb-3">How to Reach Us</h2>
      <h3 class="text-xl font-bold mb-2">General Inquiries</h3>
      <p class="mb-4">
        For general questions about Percentivo.com, our calculators, or our
        content, reach us at <a
          href="mailto:hello@percentivo.com"
          class="text-blue-600 hover:text-black">hello@percentivo.com</a
        >
      </p>

      <h3 class="text-xl font-bold mb-2">Privacy & Data Requests</h3>
      <p class="mb-4">
        For questions about your privacy, data deletion requests, or concerns
        related to our Privacy Policy at <a
          href="mailto:privacy@percentivo.com"
          class="text-blue-600">privacy@percentivo.com</a
        >
      </p>

      <h3 class="text-xl font-bold mb-2">Legal & Intellectual Property</h3>
      <p class="mb-4">
        For legal inquiries, copyright concerns, or Terms of Use questions to <a
          href="mailto:legal@percentivo.com"
          class="text-blue-600">legal@percentivo.com</a
        >
      </p>

      <h3 class="text-xl font-bold mb-2">Advertising & Sponsorships</h3>
      <p class="mb-4">
        Interested in advertising on Percentivo.com or exploring a sponsorship
        partnership? Email us at <a
          href="mailto:ads@percentivo.com"
          class="text-blue-600">ads@percentivo.com</a
        >
      </p>

      <h3 class="text-xl font-bold mb-2">Media & Press</h3>
      <p class="mb-4">
        For press inquiries, media requests, or collaboration opportunities to <a
          href="mailto:media@percentivo.com"
          class="text-blue-600">media@percentivo.com</a
        >
      </p>

      <h2 class="text-2xl font-bold mt-4">Our Response Commitment</h2>
      <p>
        We read every message. While we cannot always reply to every email, we
        commit to responding to all actionable inquiries — including error
        reports, partnership inquiries, and privacy requests — within 2–3
        business days.
      </p>

      <p class="mt-6">
        <em
          >Thank you for using Percentivo. Your feedback helps us build better
          tools for everyone.</em
        >
      </p>
    </article>
  </div>
</Base>
