---
import Base from "../layouts/Base.astro";
import FAQSection from "../components/FAQSection.astro";
import RelatedCalculators from "../components/RelatedCalculators.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
const faqs = [
  { question:"What is the percentage increase formula?", answer:"Percentage increase = ((New − Old) ÷ Old) × 100." },
  { question:"What if my result is negative?", answer:"A negative result means the value decreased. Going from 100 to 80 gives −20%." },
  { question:"Is a 100% increase the same as doubling?", answer:"Yes. A 100% increase means the value grew by its full original amount — so it doubled." },
  { question:"How is percentage increase different from percentage points?", answer:"If a rate rises from 2% to 3%, that is 1 percentage point but a 50% relative increase." },
];
---
<Base title="Percentage Increase Calculator"
  description="Calculate the percentage increase or decrease between two values. Free online tool with formula and examples."
  canonical="/percentage-increase">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={[{label:"Home",href:"/"},{label:"Percentage Increase"}]}/>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Percentage Increase Calculator</h1>
    <p class="text-gray-600 mb-8">Find the percentage increase or decrease from one value to another.</p>

    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 mb-8">
      <div class="grid grid-cols-2 gap-4 mb-4">
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5">Original value</label>
          <input id="inc-a" type="number" inputmode="decimal" placeholder="e.g. 80"
            class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50"/>
        </div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5">New value</label>
          <input id="inc-b" type="number" inputmode="decimal" placeholder="e.g. 100"
            class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50"/>
        </div>
      </div>
      <div id="inc-box" class="border rounded-xl p-5 text-center min-h-[80px] flex flex-col items-center justify-center bg-gray-50 border-gray-200">
        <div id="inc-ph" class="text-gray-400 text-sm">Enter values above to calculate</div>
        <div id="inc-ans" class="hidden">
          <div id="inc-lbl" class="text-xs mb-1"></div>
          <div id="inc-val" class="text-4xl font-bold"></div>
          <div id="inc-fml" class="text-xs font-mono mt-2"></div>
        </div>
      </div>
      <script>
        const ia=document.getElementById("inc-a") as HTMLInputElement;
        const ib=document.getElementById("inc-b") as HTMLInputElement;
        function incCalc(){
          const o=parseFloat(ia.value),n=parseFloat(ib.value);
          const ph=document.getElementById("inc-ph")!,ans=document.getElementById("inc-ans")!,box=document.getElementById("inc-box")!;
          if(!isNaN(o)&&!isNaN(n)&&o!==0){
            const pct=parseFloat((((n-o)/o)*100).toFixed(4)),isInc=pct>=0;
            document.getElementById("inc-lbl")!.className=`text-xs mb-1 ${isInc?"text-green-600":"text-amber-600"}`;
            document.getElementById("inc-lbl")!.textContent=isInc?"Percentage Increase":"Percentage Decrease";
            document.getElementById("inc-val")!.className=`text-4xl font-bold ${isInc?"text-green-700":"text-amber-700"}`;
            document.getElementById("inc-val")!.textContent=(isInc?"+":"")+pct+"%";
            document.getElementById("inc-fml")!.className=`text-xs font-mono mt-2 ${isInc?"text-green-600":"text-amber-600"}`;
            document.getElementById("inc-fml")!.textContent=`((${n}−${o})÷${o})×100=${pct}%`;
            box.className=`border rounded-xl p-5 text-center min-h-[80px] flex flex-col items-center justify-center ${isInc?"bg-green-50 border-green-200":"bg-amber-50 border-amber-200"}`;
            ph.classList.add("hidden");ans.classList.remove("hidden");
          } else {
            ph.classList.remove("hidden");ans.classList.add("hidden");
            box.className="border rounded-xl p-5 text-center min-h-[80px] flex flex-col items-center justify-center bg-gray-50 border-gray-200";
          }
        }
        ia.addEventListener("input",incCalc);ib.addEventListener("input",incCalc);
      </script>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 mb-8">
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <h2 class="font-bold text-gray-900 mb-3">The Formula</h2>
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 font-mono text-blue-800 text-sm text-center mb-3">% increase = ((New − Old) ÷ Old) × 100</div>
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-3 text-xs text-amber-800">⚠️ Always divide by the <strong>original</strong> value — dividing by the new value is the most common mistake.</div>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <h2 class="font-bold text-gray-900 mb-3">Step-by-Step (80 → 100)</h2>
        {[["1","Difference: 100 − 80 = 20"],["2","Divide by original: 20 ÷ 80 = 0.25"],["3","Multiply by 100: 0.25 × 100 = 25%"],["4","Verify: 80 × 1.25 = 100 ✓"]].map(([n,t])=>(
          <div class="flex gap-3 items-start mb-2.5 last:mb-0">
            <span class="w-6 h-6 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">{n}</span>
            <span class="text-sm text-gray-700">{t}</span>
          </div>
        ))}
      </div>
    </div>

    <FAQSection faqs={faqs}/>
    <RelatedCalculators items={[
      {label:"Percentage Decrease",href:"/percentage-decrease",desc:"Reduction between two values"},
      {label:"% of Number",        href:"/percentage-of-number",desc:"What is X% of Y?"},
      {label:"Discount Calculator",href:"/discount-calculator",desc:"Sale price and savings"},
      {label:"Markup Calculator",  href:"/markup-calculator",  desc:"Selling price from cost"},
    ]}/>
  </div>
</Base>
