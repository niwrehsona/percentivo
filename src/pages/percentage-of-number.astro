---
import Base from "../layouts/Base.astro";
import FAQSection from "../components/FAQSection.astro";
import RelatedCalculators from "../components/RelatedCalculators.astro";
import Breadcrumb from "../components/Breadcrumb.astro";
const faqs = [
  { question:"How do you calculate a percentage of a number?", answer:"Divide the percentage by 100, then multiply by the number. For example, 15% of 200 = 0.15 × 200 = 30." },
  { question:"What is 10% of a number?", answer:"Divide the number by 10. For example, 10% of 250 is 25." },
  { question:"How do I calculate 5% of a number?", answer:"Find 10% first, then halve it. 10% of 80 is 8, so 5% of 80 is 4." },
  { question:"Is there a quick way to find 15%?", answer:"Find 10%, then add half of that (5%). 15% of 200 = 20 + 10 = 30." },
];
const popular:[number,number][] = [[15,200],[20,50],[10,1000],[25,80],[5,500],[30,150],[50,200],[8,250]];
---
<Base title="Percentage of a Number Calculator"
  description="Find what X% of any number is instantly. Free percentage of number calculator with formula and step-by-step examples."
  canonical="/percentage-of-number">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <Breadcrumb items={[{label:"Home",href:"/"},{label:"Percentage of a Number"}]}/>
    <h1 class="text-3xl font-bold text-gray-900 mb-2">Percentage of a Number Calculator</h1>
    <p class="text-gray-600 mb-8">Find what X% of any number is — instantly.</p>

    <div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6 mb-8">
      <div class="grid grid-cols-[1fr_auto_1fr] gap-4 items-end mb-4">
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5">Percentage (%)</label>
          <input id="pof-a" type="number" inputmode="decimal" placeholder="e.g. 15"
            class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50"/>
        </div>
        <div class="text-gray-500 pb-2.5 text-sm font-medium">% of</div>
        <div>
          <label class="block text-xs font-medium text-gray-500 mb-1.5">Number</label>
          <input id="pof-b" type="number" inputmode="decimal" placeholder="e.g. 200"
            class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50"/>
        </div>
      </div>
      <div class="bg-green-50 border border-green-200 rounded-xl p-5 text-center min-h-[80px] flex flex-col items-center justify-center">
        <div id="pof-ph" class="text-gray-400 text-sm">Enter values above to see the answer</div>
        <div id="pof-ans" class="hidden">
          <div class="text-xs text-green-600 mb-1">Answer</div>
          <div id="pof-val" class="text-4xl font-bold text-green-700"></div>
          <div id="pof-fml" class="font-mono text-xs text-green-600 mt-2"></div>
        </div>
      </div>
      <script>
        const pa=document.getElementById("pof-a") as HTMLInputElement;
        const pb=document.getElementById("pof-b") as HTMLInputElement;
        function pofCalc(){
          const p=parseFloat(pa.value),n=parseFloat(pb.value);
          const ph=document.getElementById("pof-ph")!,ans=document.getElementById("pof-ans")!;
          if(!isNaN(p)&&!isNaN(n)){
            const r=parseFloat(((p/100)*n).toFixed(6));
            document.getElementById("pof-val")!.textContent=r.toLocaleString();
            document.getElementById("pof-fml")!.textContent=`${n} × ${p/100} = ${r.toLocaleString()}`;
            ph.classList.add("hidden");ans.classList.remove("hidden");
          } else { ph.classList.remove("hidden");ans.classList.add("hidden"); }
        }
        pa.addEventListener("input",pofCalc);pb.addEventListener("input",pofCalc);
      </script>
    </div>

    <div class="grid sm:grid-cols-2 gap-6 mb-8">
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <h2 class="font-bold text-gray-900 mb-3">The Formula</h2>
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-3 font-mono text-blue-800 text-sm text-center mb-3">Result = (P ÷ 100) × N</div>
        <p class="text-sm text-gray-600">Where <strong>P</strong> is the percentage and <strong>N</strong> is the number. Divide percentage by 100 to get its decimal, then multiply.</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-xl p-5">
        <h2 class="font-bold text-gray-900 mb-3">Step-by-Step (15% of 200)</h2>
        {[["1","Write the percentage: 15"],["2","Divide by 100 → 15 ÷ 100 = 0.15"],["3","Multiply: 0.15 × 200 = 30"]].map(([n,t])=>(
          <div class="flex gap-3 items-start mb-2.5 last:mb-0">
            <span class="w-6 h-6 bg-blue-100 text-blue-700 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0">{n}</span>
            <span class="text-sm text-gray-700">{t}</span>
          </div>
        ))}
      </div>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl p-5 mb-8">
      <h2 class="font-bold text-gray-900 mb-4">Popular Calculations</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {popular.map(([x,y])=>(
          <a href={`/what-is/${x}-percent-of-${y}`}
            class="border border-gray-200 rounded-xl p-3 text-center hover:border-blue-300 hover:bg-blue-50 transition-all">
            <div class="text-xs text-gray-500">What is</div>
            <div class="font-semibold text-sm text-gray-900">{x}% of {y}</div>
            <div class="text-blue-600 text-xs font-mono mt-1">= {parseFloat(((x/100)*y).toFixed(4))}</div>
          </a>
        ))}
      </div>
    </div>

    <FAQSection faqs={faqs}/>
    <RelatedCalculators items={[
      {label:"Percentage Increase",href:"/percentage-increase",desc:"Growth rate between two values"},
      {label:"Percentage Decrease",href:"/percentage-decrease",desc:"Reduction rate between two values"},
      {label:"Discount Calculator",href:"/discount-calculator",desc:"Sale price and savings"},
      {label:"Markup Calculator",  href:"/markup-calculator",  desc:"Selling price from cost"},
      {label:"Tax Calculator",     href:"/tax-calculator",     desc:"Sales tax and VAT"},
    ]}/>
  </div>
</Base>
