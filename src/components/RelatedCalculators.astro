---
interface Item { label: string; href: string; desc?: string }
interface Props { items: Item[] }
const { items } = Astro.props;
---
<section class="mt-10">
  <h2 class="text-xl font-bold text-gray-900 mb-4">Related Calculators</h2>
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    {items.map(item => (
      <a href={item.href}
        class="flex items-center gap-3 p-4 bg-white border border-gray-200 rounded-xl hover:border-blue-300 hover:bg-blue-50 transition-all group">
        <span class="text-2xl text-blue-400">%</span>
        <div>
          <div class="font-medium text-gray-900 text-sm group-hover:text-blue-700">{item.label}</div>
          {item.desc && <div class="text-xs text-gray-500 mt-0.5">{item.desc}</div>}
        </div>
      </a>
    ))}
  </div>
</section>
