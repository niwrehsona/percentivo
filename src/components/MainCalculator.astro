---

---

<div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6">
  <div class="flex flex-wrap gap-2 mb-6" role="tablist">
    <button
      role="tab"
      aria-selected="true"
      data-mode="pct-of"
      class="calc-tab active px-3 py-1.5 rounded-full text-sm font-medium bg-blue-600 text-white"
      >% of number</button
    >
    <button
      role="tab"
      aria-selected="false"
      data-mode="is-what-pct"
      class="calc-tab px-3 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200"
      >X is what % of Y</button
    >
    <button
      role="tab"
      aria-selected="false"
      data-mode="increase"
      class="calc-tab px-3 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200"
      >% increase</button
    >
    <button
      role="tab"
      aria-selected="false"
      data-mode="decrease"
      class="calc-tab px-3 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200"
      >% decrease</button
    >
    <button
      role="tab"
      aria-selected="false"
      data-mode="difference"
      class="calc-tab px-3 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200"
      >% difference</button
    >
  </div>
  <div class="grid grid-cols-2 gap-4 mb-4">
    <div>
      <label id="lbl-a" class="block text-xs font-medium text-gray-500 mb-1.5"
        >Percentage (%)</label
      >
      <input
        id="inp-a"
        type="number"
        inputmode="decimal"
        placeholder="e.g. 15"
        class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50 text-black"
      />
    </div>
    <div>
      <label id="lbl-b" class="block text-xs font-medium text-gray-500 mb-1.5"
        >Number</label
      >
      <input
        id="inp-b"
        type="number"
        inputmode="decimal"
        placeholder="e.g. 200"
        class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50 text-black"
      />
    </div>
  </div>
  <div
    id="res-box"
    class="bg-green-50 border border-green-200 rounded-xl p-4 text-center min-h-[80px] flex flex-col items-center justify-center"
  >
    <div id="res-ph" class="text-gray-400 text-sm">
      Enter values above to calculate
    </div>
    <div id="res-ans" class="hidden">
      <div id="res-val" class="text-3xl font-bold text-green-700"></div>
      <div id="res-fml" class="text-xs font-mono text-green-600 mt-1"></div>
    </div>
  </div>
</div>
<script>
  const MODES: Record<
    string,
    { a: string; b: string; pa: string; pb: string }
  > = {
    "pct-of": {
      a: "Percentage (%)",
      b: "Number",
      pa: "e.g. 15",
      pb: "e.g. 200",
    },
    "is-what-pct": {
      a: "Value (X)",
      b: "Total (Y)",
      pa: "e.g. 30",
      pb: "e.g. 200",
    },
    increase: {
      a: "Original value",
      b: "New value",
      pa: "e.g. 80",
      pb: "e.g. 100",
    },
    decrease: {
      a: "Original value",
      b: "New value",
      pa: "e.g. 100",
      pb: "e.g. 75",
    },
    difference: { a: "Value A", b: "Value B", pa: "e.g. 80", pb: "e.g. 100" },
  };
  let mode = "pct-of";
  const la = document.getElementById("lbl-a")!;
  const lb = document.getElementById("lbl-b")!;
  const ia = document.getElementById("inp-a") as HTMLInputElement;
  const ib = document.getElementById("inp-b") as HTMLInputElement;
  const box = document.getElementById("res-box")!;
  const ph = document.getElementById("res-ph")!;
  const ans = document.getElementById("res-ans")!;
  const val = document.getElementById("res-val")!;
  const fml = document.getElementById("res-fml")!;

  function run() {
    const a = parseFloat(ia.value),
      b = parseFloat(ib.value);
    if (isNaN(a) || isNaN(b)) {
      ph.classList.remove("hidden");
      ans.classList.add("hidden");
      return;
    }
    let r = "",
      f = "";
    if (mode === "pct-of") {
      const v = (a / 100) * b;
      r = parseFloat(v.toFixed(6)).toLocaleString();
      f = `${b} × ${a / 100} = ${r}`;
    } else if (mode === "is-what-pct" && b) {
      const v = (a / b) * 100;
      r = parseFloat(v.toFixed(4)) + "%";
      f = `(${a}÷${b})×100=${r}`;
    } else if (mode === "increase" && a) {
      const v = ((b - a) / a) * 100;
      r = (v >= 0 ? "+" : "") + parseFloat(v.toFixed(4)) + "%";
      f = `((${b}−${a})÷${a})×100=${r}`;
    } else if (mode === "decrease" && a) {
      const v = ((a - b) / a) * 100;
      r = parseFloat(v.toFixed(4)) + "%";
      f = `((${a}−${b})÷${a})×100=${r}`;
    } else if (mode === "difference") {
      const avg = (a + b) / 2;
      if (!avg) return;
      const v = (Math.abs(a - b) / avg) * 100;
      r = parseFloat(v.toFixed(4)) + "%";
      f = `|${a}−${b}|÷avg×100=${r}`;
    }
    if (r) {
      ph.classList.add("hidden");
      ans.classList.remove("hidden");
      val.textContent = r;
      fml.textContent = f;
    } else {
      ph.classList.remove("hidden");
      ans.classList.add("hidden");
    }
  }

  function setMode(m: string) {
    mode = m;
    const cfg = MODES[m];
    la.textContent = cfg.a;
    lb.textContent = cfg.b;
    ia.placeholder = cfg.pa;
    ib.placeholder = cfg.pb;
    ia.value = "";
    ib.value = "";
    ph.classList.remove("hidden");
    ans.classList.add("hidden");
    document.querySelectorAll(".calc-tab").forEach((btn) => {
      const on = (btn as HTMLElement).dataset.mode === m;
      btn.className = `calc-tab px-3 py-1.5 rounded-full text-sm font-medium ${on ? "bg-blue-600 text-white" : "bg-gray-100 text-gray-600 hover:bg-gray-200"}`;
      btn.setAttribute("aria-selected", String(on));
    });
  }
  document
    .querySelectorAll(".calc-tab")
    .forEach((b) =>
      b.addEventListener("click", () =>
        setMode((b as HTMLElement).dataset.mode!),
      ),
    );
  ia.addEventListener("input", run);
  ib.addEventListener("input", run);
</script>
