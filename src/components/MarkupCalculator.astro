---
---
<div class="bg-white border border-gray-200 rounded-2xl shadow-sm p-6">
  <div class="flex flex-wrap gap-2 mb-6">
    <button data-mode="cost-to-price" class="m-tab active px-3 py-1.5 rounded-full text-sm font-medium bg-blue-600 text-white">Cost + markup → price</button>
    <button data-mode="find-markup"   class="m-tab px-3 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200">Cost + price → markup %</button>
    <button data-mode="find-cost"     class="m-tab px-3 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200">Price + markup → cost</button>
    <button data-mode="converter"     class="m-tab px-3 py-1.5 rounded-full text-sm font-medium bg-gray-100 text-gray-600 hover:bg-gray-200">Markup ↔ Margin</button>
  </div>
  <div class="grid grid-cols-2 gap-4 mb-4">
    <div>
      <label id="m-la" class="block text-xs font-medium text-gray-500 mb-1.5">Cost price ($)</label>
      <input id="m-a" type="number" inputmode="decimal" placeholder="e.g. 40"
        class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50"/>
    </div>
    <div>
      <label id="m-lb" class="block text-xs font-medium text-gray-500 mb-1.5">Markup (%)</label>
      <input id="m-b" type="number" inputmode="decimal" placeholder="e.g. 50"
        class="w-full px-3 py-2.5 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 bg-gray-50"/>
    </div>
  </div>
  <div id="m-box" class="border rounded-xl p-4 min-h-[90px] bg-green-50 border-green-200">
    <div id="m-ph" class="text-center text-gray-400 text-sm pt-2">Enter values above to calculate</div>
    <div id="m-rows" class="hidden space-y-1"></div>
    <div id="m-fml" class="hidden font-mono text-xs mt-2 opacity-70"></div>
  </div>
</div>
<script>
type MMode="cost-to-price"|"find-markup"|"find-cost"|"converter";
let mMode:MMode="cost-to-price";
const mFmt=(n:number)=>"$"+parseFloat(n.toFixed(2)).toLocaleString("en-US",{minimumFractionDigits:2,maximumFractionDigits:2});
const mPct=(n:number)=>parseFloat(n.toFixed(2))+"%";
const mCols:Record<MMode,string>={
  "cost-to-price":"bg-green-50 border-green-200",
  "find-markup":  "bg-blue-50 border-blue-200",
  "find-cost":    "bg-amber-50 border-amber-200",
  "converter":    "bg-purple-50 border-purple-200",
};
const mLbls:Record<MMode,[string,string,string,string]>={
  "cost-to-price":["Cost price ($)","e.g. 40","Markup (%)","e.g. 50"],
  "find-markup":  ["Cost price ($)","e.g. 40","Selling price ($)","e.g. 60"],
  "find-cost":    ["Selling price ($)","e.g. 60","Markup (%)","e.g. 50"],
  "converter":    ["Markup (%)","e.g. 50","Or margin (%)","e.g. 33.3"],
};
function mCalc(){
  const a=parseFloat((document.getElementById("m-a") as HTMLInputElement).value);
  const b=parseFloat((document.getElementById("m-b") as HTMLInputElement).value);
  const ph=document.getElementById("m-ph")!,rows=document.getElementById("m-rows")!,fml=document.getElementById("m-fml")!,box=document.getElementById("m-box")!;
  if(isNaN(a)||isNaN(b)){ph.classList.remove("hidden");rows.classList.add("hidden");fml.classList.add("hidden");return;}
  let rData:[string,string,boolean][]=[];let f="";
  if(mMode==="cost-to-price"){const p=a*(1+b/100),pr=p-a,mg=(pr/p)*100;rData=[["Selling price",mFmt(p),true],["Gross profit",mFmt(pr),false],["Gross margin",mPct(mg),false]];f=`${a}×(1+${b}/100)=${mFmt(p)}`;}
  else if(mMode==="find-markup"){if(!a)return;const mu=((b-a)/a)*100,mg=((b-a)/b)*100,pr=b-a;rData=[["Markup %",mPct(mu),true],["Gross profit",mFmt(pr),false],["Gross margin",mPct(mg),false]];f=`((${b}−${a})÷${a})×100=${mPct(mu)}`;}
  else if(mMode==="find-cost"){const c=a/(1+b/100),pr=a-c,mg=((a-c)/a)*100;rData=[["Cost price",mFmt(c),true],["Gross profit",mFmt(pr),false],["Gross margin",mPct(mg),false]];f=`${a}÷(1+${b}/100)=${mFmt(c)}`;}
  else{const mg=a/(1+a/100),mu=b/(1-b/100);rData=[[`${a}% markup → margin`,mPct(mg),true],[`${b}% margin → markup`,mPct(mu),false]];f=`${a}÷(1+${a}/100)=${mPct(mg)}`;}
  ph.classList.add("hidden");
  rows.innerHTML=rData.map(([l,v,big])=>`<div class="flex justify-between items-center py-1 border-b border-current border-opacity-10 last:border-0"><span class="text-sm">${l}</span><span class="${big?"text-2xl font-bold":"font-semibold text-sm"}">${v}</span></div>`).join("");
  rows.classList.remove("hidden");fml.textContent=f;fml.classList.remove("hidden");
  box.className=`border rounded-xl p-4 min-h-[90px] ${mCols[mMode]}`;
}
function mSet(m:MMode){
  mMode=m;const[la,pa,lb,pb]=mLbls[m];
  (document.getElementById("m-la") as HTMLElement).textContent=la;
  (document.getElementById("m-lb") as HTMLElement).textContent=lb;
  (document.getElementById("m-a") as HTMLInputElement).placeholder=pa;
  (document.getElementById("m-b") as HTMLInputElement).placeholder=pb;
  (document.getElementById("m-a") as HTMLInputElement).value="";
  (document.getElementById("m-b") as HTMLInputElement).value="";
  document.getElementById("m-ph")!.classList.remove("hidden");
  document.getElementById("m-rows")!.classList.add("hidden");
  document.getElementById("m-fml")!.classList.add("hidden");
  document.querySelectorAll(".m-tab").forEach(b=>{
    const on=(b as HTMLElement).dataset.mode===m;
    b.className=`m-tab px-3 py-1.5 rounded-full text-sm font-medium ${on?"bg-blue-600 text-white":"bg-gray-100 text-gray-600 hover:bg-gray-200"}`;
  });
}
document.querySelectorAll(".m-tab").forEach(b=>b.addEventListener("click",()=>mSet((b as HTMLElement).dataset.mode as MMode)));
document.getElementById("m-a")!.addEventListener("input",mCalc);
document.getElementById("m-b")!.addEventListener("input",mCalc);
</script>
