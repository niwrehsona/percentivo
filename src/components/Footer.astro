<script>
  class MobileMenuEl extends HTMLElement {
    connectedCallback() {
      const btn = this.querySelector("#menu-btn")!;
      const nav = this.querySelector("#mobile-nav")!;
      const iconO = this.querySelector("#icon-open")!;
      const iconC = this.querySelector("#icon-close")!;
      const calcBtn = this.querySelector("#calc-btn")!;
      const calcNav = this.querySelector("#calc-nav")!;
      const calcIcon = this.querySelector("#calc-icon")!;
      let open = false,
        calcOpen = false;

      btn.addEventListener("click", () => {
        open = !open;
        nav.classList.toggle("opacity-100", open);
        nav.classList.toggle("scale-y-100", open);
        nav.classList.toggle("pointer-events-auto", open);
        nav.classList.toggle("opacity-0", !open);
        nav.classList.toggle("scale-y-0", !open);
        nav.classList.toggle("pointer-events-none", !open);
        nav.setAttribute("aria-hidden", String(!open));
        btn.setAttribute("aria-expanded", String(open));
        iconO.classList.toggle("hidden", open);
        iconC.classList.toggle("hidden", !open);
      });

      calcBtn.addEventListener("click", () => {
        calcOpen = !calcOpen;
        calcNav.classList.toggle("max-h-96", calcOpen);
        calcNav.classList.toggle("max-h-0", !calcOpen);
        (calcIcon as HTMLElement).style.transform = calcOpen
          ? "rotate(180deg)"
          : "";
        calcBtn.setAttribute("aria-expanded", String(calcOpen));
      });
    }
  }
  customElements.define("mobile-menu", MobileMenuEl);
</script>
